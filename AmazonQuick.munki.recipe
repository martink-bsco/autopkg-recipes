<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Description</key>
    <string>Imports Amazon Quick into Munki.</string>
    <key>Identifier</key>
    <string>com.github.martink-bsco.munki.amazonquick</string>
    <key>Input</key>
    <dict>
        <key>DISPLAY_NAME</key>
        <string>Amazon Quick</string>
        <key>MUNKI_CATEGORY</key>
        <string>Productivity</string>
        <key>NAME</key>
        <string>AmazonQuick</string>
        <key>MUNKI_REPO_SUBDIR</key>
        <string>apps/%NAME%</string>
        <key>pkginfo</key>
        <dict>
            <key>catalogs</key>
            <array>
                <string>selfservice</string>
            </array>
            <key>category</key>
            <string>%MUNKI_CATEGORY%</string>
            <key>description</key>
            <string>Amazon Quick</string>
            <key>developer</key>
            <string>Amazon</string>
            <key>display_name</key>
            <string>%DISPLAY_NAME%</string>
            <key>minimum_os_version</key>
            <string>10.7.0</string>
            <key>name</key>
            <string>%NAME%</string>
            <key>unattended_install</key>
            <true />
        </dict>
    </dict>
    <key>MinimumVersion</key>
    <string>0.1000.1123</string>
    <key>ParentRecipe</key>
    <string>com.github.martink-bsco.download.amazonquick</string>
    <key>Process</key>
    <array>
        <dict>
            <key>Arguments</key>
            <dict>
                <key>pkg_path</key>
                <string>%pathname%</string>
                <key>repo_subdirectory</key>
                <string>%MUNKI_REPO_SUBDIR%</string>
            </dict>
            <key>Processor</key>
            <string>MunkiImporter</string>
        </dict>
    </array>
</dict>
</plist>
